{
  "OpenTelemetry": {
    "Otlp": {
      "Endpoint": "http://localhost:4317"
    }
  },
  "Jwt": {
    "Issuer": "hotel-erp",
    "Audience": "hotel-erp-clients",
    "CurrentKeyId": "k1",
    "Keys": [
      {
        "KeyId": "k1",
        "Secret": "CHANGE_THIS_K1_IN_PRODUCTION_WITH_32+_CHAR_SECRET"
      },
      {
        "KeyId": "k0",
        "Secret": "CHANGE_THIS_K0_IN_PRODUCTION_WITH_32+_CHAR_SECRET"
      }
    ],
    "SigningKey": "CHANGE_THIS_IN_PRODUCTION_WITH_32+_CHAR_SECRET",
    "AccessTokenMinutes": 60
  },
  "Auth": {
    "ClientId": "hotel-ops",
    "ClientSecret": "hotel-ops-secret",
    "RefreshTokenDays": 14,
    "MaxFailedAttempts": 5,
    "LockoutMinutes": 15
  },
  "Compliance": {
    "SecurityAuditRetentionDays": 365,
    "IpAnonymizationDays": 30
  },
  "Mcp": {
    "Quota": {
      "RequestsPerMinutePerClient": 60
    }
  },
  "LocalExecution": {
    "Profile": "local-inmemory",
    "PreferredDatabaseProvider": "inmemory",
    "EnableDatabaseFallback": true,
    "InMemoryDatabaseName": "hotel-erp-local"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "HotelDb": "",
    "HotelDbPostgresExample": "Host=/var/run/postgresql;Database=hotel_erp;Username=gabriel"
  }
}